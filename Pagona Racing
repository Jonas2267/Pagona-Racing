<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Pagona Racing – Sim-Racing-Team mit Fokus auf Präzision, Fortschritt und Teamgeist." />
  <title>Pagona Racing | Precision in Motion</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <style>
    :root {
      --accent-green: #a7ff19;
      --accent-green-2: #7bff00;
      --accent-purple: #7a3de3;
      --accent-purple-dark: #3c1a86;
      --bg-black: #0b0b0f;
      --bg-surface: #111218;
      --text-primary: #ffffff;
      --text-secondary: #b8b8c0;
      --glass-bg: rgba(255, 255, 255, 0.07);
      --glass-border: rgba(255, 255, 255, 0.12);
      --radius-lg: 24px;
      --radius-md: 18px;
      --shadow-soft: 0 24px 50px rgba(0, 0, 0, 0.38);
      --container: min(1120px, calc(100% - 3rem));
      --transition: 320ms cubic-bezier(.22, .61, .36, 1);
    }

    * { box-sizing: border-box; }

    html {
      scroll-behavior: smooth;
    }

    body {
      margin: 0;
      font-family: "Inter", system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
      color: var(--text-primary);
      background:
        radial-gradient(circle at 14% 8%, rgba(122, 61, 227, 0.20), transparent 34%),
        radial-gradient(circle at 86% 16%, rgba(123, 255, 0, 0.10), transparent 30%),
        radial-gradient(circle at 52% 78%, rgba(60, 26, 134, 0.26), transparent 42%),
        linear-gradient(160deg, #09090d 0%, #0b0b0f 55%, #111218 100%);
      line-height: 1.6;
      overflow-x: hidden;
      min-height: 100vh;
    }

    body::before,
    body::after {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: -1;
    }

    body::before {
      background:
        radial-gradient(600px 260px at var(--mx, 50%) calc(var(--my, 50%) - 12%), rgba(122, 61, 227, 0.16), transparent 72%),
        radial-gradient(460px 220px at calc(var(--mx, 50%) - 10%) calc(var(--my, 50%) + 6%), rgba(123, 255, 0, 0.07), transparent 75%);
      transition: background 0.25s ease;
    }

    body::after {
      background-image: linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
      background-size: 48px 48px;
      mask-image: radial-gradient(circle at 50% 15%, black, transparent 72%);
      opacity: 0.35;
    }

    .container { width: var(--container); margin-inline: auto; }

    .glass {
      background: linear-gradient(140deg, rgba(255, 255, 255, 0.09), rgba(255, 255, 255, 0.04));
      border: 1px solid var(--glass-border);
      box-shadow: var(--shadow-soft);
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
    }

    .top-nav {
      position: sticky;
      top: 16px;
      z-index: 1000;
      width: var(--container);
      margin: 16px auto 0;
      padding: 0.7rem 1rem;
      border-radius: 999px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .brand {
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      font-weight: 700;
      text-decoration: none;
      color: var(--text-primary);
      letter-spacing: 0.01em;
    }

    .brand img {
      width: 34px;
      height: 34px;
      object-fit: contain;
      border-radius: 10px;
      background: rgba(255, 255, 255, 0.06);
      border: 1px solid rgba(255, 255, 255, 0.14);
      padding: 0.2rem;
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 0.35rem;
      flex-wrap: wrap;
    }

    .nav-links a {
      color: var(--text-secondary);
      text-decoration: none;
      font-size: 0.92rem;
      font-weight: 500;
      padding: 0.52rem 0.9rem;
      border-radius: 999px;
      border: 1px solid transparent;
      transition: all var(--transition);
    }

    .nav-links a:hover,
    .nav-links a:focus-visible {
      color: var(--text-primary);
      border-color: rgba(167, 255, 25, 0.35);
      background: rgba(167, 255, 25, 0.08);
      box-shadow: 0 0 0 1px rgba(167, 255, 25, 0.14) inset;
      outline: none;
    }

    main { padding-bottom: 4rem; }

    section {
      padding: 5rem 0;
      position: relative;
    }

    .hero {
      min-height: calc(100vh - 110px);
      display: grid;
      align-items: center;
      padding-top: 3.5rem;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: 1.05fr 0.95fr;
      align-items: center;
      gap: 2rem;
    }

    .eyebrow {
      display: inline-block;
      color: var(--accent-green);
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.17em;
      margin-bottom: 0.9rem;
      opacity: 0.9;
    }

    h1, h2, h3 { line-height: 1.15; margin: 0 0 0.75rem; }
    h1 { font-size: clamp(2rem, 4vw, 3.9rem); letter-spacing: -0.03em; }
    h2 { font-size: clamp(1.6rem, 2.6vw, 2.4rem); letter-spacing: -0.02em; }

    .motto {
      font-weight: 600;
      font-size: clamp(1.05rem, 2vw, 1.3rem);
      color: var(--text-secondary);
      margin-bottom: 1.3rem;
    }

    .hero p,
    .section-copy,
    .footer-copy { color: var(--text-secondary); max-width: 56ch; }

    .hero-actions {
      margin-top: 1.9rem;
      display: flex;
      gap: 0.85rem;
      flex-wrap: wrap;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      font-weight: 600;
      border-radius: 999px;
      border: 1px solid transparent;
      text-decoration: none;
      transition: transform var(--transition), box-shadow var(--transition), background var(--transition), border-color var(--transition), color var(--transition);
      will-change: transform;
      padding: 0.78rem 1.25rem;
      font-size: 0.95rem;
    }

    .btn-primary {
      background: linear-gradient(90deg, rgba(122, 61, 227, 0.52), rgba(123, 255, 0, 0.30));
      border-color: rgba(167, 255, 25, 0.32);
      color: #f8fff0;
      box-shadow: 0 8px 24px rgba(123, 255, 0, 0.13), 0 8px 24px rgba(122, 61, 227, 0.18);
    }

    .btn-secondary {
      border-color: rgba(255, 255, 255, 0.2);
      background: rgba(255, 255, 255, 0.03);
      color: var(--text-primary);
    }

    .btn:hover,
    .btn:focus-visible {
      transform: translateY(-2px);
      outline: none;
    }

    .btn-primary:hover,
    .btn-primary:focus-visible {
      box-shadow: 0 12px 32px rgba(123, 255, 0, 0.18), 0 12px 32px rgba(122, 61, 227, 0.2);
      border-color: rgba(167, 255, 25, 0.48);
    }

    .btn-secondary:hover,
    .btn-secondary:focus-visible {
      border-color: rgba(167, 255, 25, 0.4);
      background: rgba(167, 255, 25, 0.08);
    }

    .hero-card {
      border-radius: var(--radius-lg);
      padding: 1.2rem;
      position: relative;
      overflow: hidden;
      transform-style: preserve-3d;
      transition: transform var(--transition);
    }

    .hero-card::before {
      content: "";
      position: absolute;
      inset: -20% -8% auto;
      height: 56%;
      background: radial-gradient(circle at center, rgba(167, 255, 25, 0.19), transparent 70%);
      opacity: 0.85;
      pointer-events: none;
    }

    .hero-logo-wrap {
      position: relative;
      border-radius: calc(var(--radius-lg) - 8px);
      background: linear-gradient(135deg, rgba(60, 26, 134, 0.3), rgba(17, 18, 24, 0.78));
      border: 1px solid rgba(255, 255, 255, 0.15);
      min-height: 390px;
      display: grid;
      place-items: center;
      overflow: hidden;
      isolation: isolate;
    }

    .hero-logo-wrap::before,
    .hero-logo-wrap::after {
      content: "";
      position: absolute;
      border-radius: 999px;
      filter: blur(34px);
      opacity: 0.4;
      z-index: -1;
    }

    .hero-logo-wrap::before {
      width: 280px;
      height: 280px;
      background: rgba(122, 61, 227, 0.45);
      top: -90px;
      right: -70px;
    }

    .hero-logo-wrap::after {
      width: 250px;
      height: 250px;
      background: rgba(123, 255, 0, 0.28);
      bottom: -100px;
      left: -80px;
    }

    .hero-logo-wrap img {
      width: min(90%, 520px);
      height: auto;
      filter: drop-shadow(0 18px 28px rgba(0, 0, 0, 0.45));
      object-fit: contain;
    }

    .logo-fallback {
      display: none;
      font-size: 1.6rem;
      font-weight: 700;
      letter-spacing: 0.02em;
      padding: 1.2rem 1.4rem;
      border-radius: 14px;
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.14);
    }

    .section-head {
      margin-bottom: 1.7rem;
      display: grid;
      gap: 0.35rem;
    }

    .about-card,
    .vision-card,
    .contact-card {
      padding: clamp(1.2rem, 2vw, 2rem);
      border-radius: var(--radius-lg);
    }

    .meta-grid,
    .values-grid {
      display: grid;
      gap: 1rem;
    }

    .meta-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      margin-top: 1.2rem;
    }

    .meta-item {
      padding: 0.9rem 1rem;
      border-radius: var(--radius-md);
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid rgba(255, 255, 255, 0.11);
      color: var(--text-secondary);
    }

    .meta-item strong {
      display: block;
      color: var(--text-primary);
      margin-bottom: 0.2rem;
      font-size: 1.03rem;
    }

    .values-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      margin-top: 0.5rem;
    }

    .value-card {
      padding: 1.15rem;
      border-radius: var(--radius-md);
      background: linear-gradient(140deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.04));
      border: 1px solid rgba(255, 255, 255, 0.12);
      transition: transform var(--transition), border-color var(--transition), box-shadow var(--transition);
    }

    .value-card:hover {
      transform: translateY(-4px);
      border-color: rgba(167, 255, 25, 0.35);
      box-shadow: 0 10px 25px rgba(122, 61, 227, 0.18);
    }

    .value-icon {
      width: 2.2rem;
      height: 2.2rem;
      border-radius: 10px;
      display: grid;
      place-items: center;
      margin-bottom: 0.7rem;
      background: linear-gradient(135deg, rgba(122, 61, 227, 0.42), rgba(167, 255, 25, 0.2));
      border: 1px solid rgba(255, 255, 255, 0.15);
      color: #f2fee0;
      font-size: 1.1rem;
    }

    .value-card h3 { font-size: 1.04rem; margin-bottom: 0.45rem; }
    .value-card p { margin: 0; color: var(--text-secondary); font-size: 0.95rem; }

    .contact-actions { margin-top: 1.35rem; }

    footer {
      border-top: 1px solid rgba(255, 255, 255, 0.09);
      padding: 1.7rem 0 2.6rem;
      color: #a4a4af;
      font-size: 0.9rem;
      text-align: center;
    }

    .reveal {
      opacity: 0;
      transform: translateY(20px) scale(0.99);
      transition: opacity 560ms cubic-bezier(.2, .7, .2, 1), transform 560ms cubic-bezier(.2, .7, .2, 1);
    }

    .reveal.is-visible {
      opacity: 1;
      transform: translateY(0) scale(1);
    }

    @media (max-width: 980px) {
      .hero-grid,
      .values-grid { grid-template-columns: 1fr 1fr; }

      .hero-logo-wrap { min-height: 330px; }
    }

    @media (max-width: 760px) {
      .top-nav {
        top: 8px;
        border-radius: 22px;
        width: calc(100% - 1rem);
      }

      .brand span { font-size: 0.95rem; }
      .nav-links a { padding-inline: 0.7rem; font-size: 0.85rem; }
      section { padding: 4rem 0; }
      .hero { min-height: auto; }
      .hero-grid,
      .values-grid,
      .meta-grid { grid-template-columns: 1fr; }
      .hero-logo-wrap { min-height: 290px; }
    }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
        scroll-behavior: auto !important;
      }
    }
  </style>
</head>
<body>
  <header class="top-nav glass">
    <a href="#home" class="brand" aria-label="Pagona Racing Startseite">
      <img src="assets/pagona-logo.png" alt="Pagona Racing Logo" />
      <span>Pagona Racing</span>
    </a>
    <nav class="nav-links" aria-label="Hauptnavigation">
      <a href="#home">Home</a>
      <a href="#about">Über uns</a>
      <a href="#values">Werte</a>
      <a href="#vision">Vision</a>
      <a href="#contact">Kontakt</a>
    </nav>
  </header>

  <main>
    <section id="home" class="hero">
      <div class="container hero-grid">
        <div class="reveal">
          <span class="eyebrow">Pagona Racing</span>
          <h1>Herzlich willkommen bei Pagona Racing</h1>
          <p class="motto">Precision in Motion</p>
          <p>
            Wir sind ein ambitioniertes Sim-Racing-Team mit klarem Fokus auf Präzision,
            Weiterentwicklung und starke Teamdynamik. Unser Anspruch: professionell fahren,
            gemeinsam wachsen und jede Runde besser werden.
          </p>
          <div class="hero-actions">
            <a class="btn btn-primary" href="#about">Mehr erfahren</a>
            <a class="btn btn-secondary" href="https://instagram.com" target="_blank" rel="noreferrer">Instagram</a>
          </div>
        </div>
        <div class="hero-card glass reveal" aria-hidden="true">
          <div class="hero-logo-wrap">
            <img src="assets/pagona-logo.png" alt="Pagona Racing Emblem" id="heroLogo" />
            <div class="logo-fallback" id="logoFallback">Pagona Racing</div>
          </div>
        </div>
      </div>
    </section>

    <section id="about">
      <div class="container">
        <article class="about-card glass reveal">
          <div class="section-head">
            <span class="eyebrow">Über uns</span>
            <h2>Ambitioniert. Konzentriert. Gemeinsam.</h2>
          </div>
          <p class="section-copy">
            Pagona Racing wurde am <strong>08.03.2026</strong> von <strong>Jonas</strong> und <strong>Chris</strong> gegründet.
            Seit dem ersten Tag verbinden wir Leistungsanspruch mit echter Teamkultur – klar,
            respektvoll und mit Blick nach vorn.
          </p>
          <div class="meta-grid">
            <div class="meta-item">
              <strong>Gegründet</strong>
              08.03.2026
            </div>
            <div class="meta-item">
              <strong>Gründer</strong>
              Jonas &amp; Chris
            </div>
          </div>
        </article>
      </div>
    </section>

    <section id="values">
      <div class="container">
        <div class="section-head reveal">
          <span class="eyebrow">Werte</span>
          <h2>Was uns ausmacht</h2>
        </div>
        <div class="values-grid reveal">
          <article class="value-card">
            <div class="value-icon">◎</div>
            <h3>Präzision</h3>
            <p>Wir arbeiten an Details, entscheiden bewusst und liefern konstant ab.</p>
          </article>
          <article class="value-card">
            <div class="value-icon">✦</div>
            <h3>Teamgeist</h3>
            <p>Stärke entsteht im Miteinander – mit Vertrauen, Klarheit und gemeinsamer Energie.</p>
          </article>
          <article class="value-card">
            <div class="value-icon">↗</div>
            <h3>Zielstrebigkeit</h3>
            <p>Wir entwickeln uns stetig weiter, suchen Herausforderungen und bleiben fokussiert.</p>
          </article>
          <article class="value-card">
            <div class="value-icon">∞</div>
            <h3>Respekt &amp; Community</h3>
            <p>Leistung und soziales Miteinander gehören für uns untrennbar zusammen.</p>
          </article>
        </div>
      </div>
    </section>

    <section id="vision">
      <div class="container">
        <article class="vision-card glass reveal">
          <div class="section-head">
            <span class="eyebrow">Vision</span>
            <h2>Wachsen. Mitfahren. Gemeinsam erfolgreich sein.</h2>
          </div>
          <p class="section-copy">
            Unser Ziel ist es, als Team kontinuierlich größer zu werden, an Rennen teilzunehmen
            und unser Niveau auf ein neues Level zu heben. Wir verbinden Performance mit Community –
            motiviert, diszipliniert und mit klarem Blick auf die Zukunft.
          </p>
        </article>
      </div>
    </section>

    <section id="contact">
      <div class="container">
        <article class="contact-card glass reveal">
          <div class="section-head">
            <span class="eyebrow">Kontakt</span>
            <h2>Begleite Pagona Racing auf dem nächsten Schritt.</h2>
          </div>
          <p class="section-copy">
            Folge uns auf Instagram und werde Teil einer Community, die Präzision, Leidenschaft und
            Zusammenhalt lebt.
          </p>
          <div class="contact-actions">
            <a class="btn btn-primary" href="https://instagram.com" target="_blank" rel="noreferrer">Zu Instagram</a>
          </div>
        </article>
      </div>
    </section>
  </main>

  <footer>
    <div class="container footer-copy">© 2026 Pagona Racing · Precision in Motion</div>
  </footer>

  <script>
    (() => {
      const revealElements = document.querySelectorAll('.reveal');
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.18, rootMargin: '0px 0px -8% 0px' });

      revealElements.forEach((element) => observer.observe(element));

      const root = document.body;
      let rafId = null;

      const updatePointerGlow = (x, y) => {
        root.style.setProperty('--mx', `${x}px`);
        root.style.setProperty('--my', `${y}px`);
      };

      window.addEventListener('pointermove', (event) => {
        if (rafId) return;
        rafId = requestAnimationFrame(() => {
          updatePointerGlow(event.clientX, event.clientY);
          rafId = null;
        });
      }, { passive: true });

      const heroLogo = document.getElementById('heroLogo');
      const logoFallback = document.getElementById('logoFallback');
      const showFallback = () => {
        if (!heroLogo || !logoFallback) return;
        heroLogo.style.display = 'none';
        logoFallback.style.display = 'inline-block';
      };

      if (heroLogo) {
        heroLogo.addEventListener('error', showFallback, { once: true });
      }
    })();
  </script>
</body>
</html>
